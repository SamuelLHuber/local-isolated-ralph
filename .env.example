# Copy this file to a local `.env` or workflow-specific env file such as
# `.env.dispatch`, then fill in the values needed for your run.

# Required for PI-backed workflows that use the Fireworks Kimi model.
export FIREWORKS_API_KEY=fw_your_api_key_here

# Set one of these when the workflow must clone or push to a private GitHub repo.
export GITHUB_TOKEN=ghp_your_github_token_here
# export GH_TOKEN=ghp_your_github_token_here

# Set these when the workflow is expected to create commits or move bookmarks.
export JJ_USER_NAME="Your Name"
export JJ_USER_EMAIL=you@example.com

# Optional workflow tuning knobs.
# export MAX_TODO_ITEMS=1
# export MAX_REVIEW_ROUNDS=8
# export MAX_TODO_LOOP_ITERATIONS=64

# Shared runtime credentials (ANTHROPIC_API_KEY, OPENAI_API_KEY, etc.)
# are managed via kubectl in fabrik-system, not in dotenv files.
# See src/fabrik-runtime/README.md for the credential model.
