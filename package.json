{
  "name": "fabrik",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/fabrik-runtime"
  ],
  "bin": {
    "fabrik": "dist/fabrik"
  },
  "scripts": {
    "changeset-version": "changeset version && node scripts/version.mjs",
    "changeset-publish": "bun run build && node scripts/publish.mjs",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit"
  },
  "dependencies": {
    "@dtechvision/fabrik-runtime": "workspace:*",
    "smithers-orchestrator": "0.9.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0"
  },
  "trustedDependencies": []
}
